# Henchmen configuration
# Copy to .env.local: cp .env.example .env.local

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
HENCHMEN_PROVIDER=local
# Per-service overrides (leave empty to use default):
# HENCHMEN_LLM_PROVIDER=openai
# HENCHMEN_MESSAGE_BROKER_PROVIDER=
# HENCHMEN_DOCUMENT_STORE_PROVIDER=
# HENCHMEN_OBJECT_STORE_PROVIDER=
# HENCHMEN_CONTAINER_ORCHESTRATOR_PROVIDER=
# HENCHMEN_CI_PROVIDER=

# =============================================================================
# ENVIRONMENT
# =============================================================================
HENCHMEN_ENVIRONMENT=dev

# =============================================================================
# GITHUB (required for full workflow, optional for dry-run)
# =============================================================================
# HENCHMEN_GITHUB_APP_ID=
# HENCHMEN_GITHUB_APP_PRIVATE_KEY_SECRET=
# HENCHMEN_GITHUB_DEFAULT_ORG=your-org
# HENCHMEN_GITHUB_DEFAULT_REPO=your-org/your-repo

# =============================================================================
# GIT IDENTITY
# =============================================================================
HENCHMEN_GIT_AUTHOR_NAME=Henchmen Operative
HENCHMEN_GIT_AUTHOR_EMAIL=henchmen-operative@noreply.local

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
# Henchmen is BYO-LLM. Pick one option below and uncomment the corresponding
# block. OpenAI is the recommended default because its tool-calling is the
# most reliable for the Operative agent loop. Anthropic is a drop-in
# alternative. Ollama is supported but experimental — most local models
# struggle with the multi-step tool-calling Henchmen requires.
#
# See docs/byo-llm.md for a full comparison and model recommendations.

# -----------------------------------------------------------------------------
# LLM — OPTION A: OpenAI (recommended)
# -----------------------------------------------------------------------------
# Get an API key: https://platform.openai.com/api-keys
HENCHMEN_LLM_PROVIDER=openai
HENCHMEN_OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# LLM — OPTION B: Anthropic
# -----------------------------------------------------------------------------
# Get an API key: https://console.anthropic.com/settings/keys
# HENCHMEN_LLM_PROVIDER=anthropic
# HENCHMEN_ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# LLM — OPTION C: Ollama (experimental — see README for tool-calling-capable
# model recommendations)
# -----------------------------------------------------------------------------
# Ollama must be running: https://ollama.com
# Pull a tool-calling-capable model, e.g.: ollama pull qwen2.5-coder:7b
# HENCHMEN_LLM_PROVIDER=ollama
# HENCHMEN_LLM_OLLAMA_BASE_URL=http://localhost:11434
# HENCHMEN_LLM_OLLAMA_MODEL=qwen2.5-coder:7b

# =============================================================================
# GCP (only when HENCHMEN_PROVIDER=gcp)
# =============================================================================
# HENCHMEN_GCP_PROJECT_ID=
# HENCHMEN_GCP_REGION=us-central1

# =============================================================================
# AWS (only when HENCHMEN_PROVIDER=aws)
# =============================================================================
# HENCHMEN_AWS_REGION=us-east-1
# HENCHMEN_AWS_ACCOUNT_ID=

# =============================================================================
# DIRECT API KEYS (only for openai/anthropic LLM providers)
# =============================================================================
# HENCHMEN_OPENAI_API_KEY=sk-...
# HENCHMEN_ANTHROPIC_API_KEY=sk-ant-...
