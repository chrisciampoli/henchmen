# Henchmen configuration
# Copy to .env.local: cp .env.example .env.local

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
HENCHMEN_PROVIDER=local
# Per-service overrides (leave empty to use default):
# HENCHMEN_LLM_PROVIDER=openai
# HENCHMEN_MESSAGE_BROKER_PROVIDER=
# HENCHMEN_DOCUMENT_STORE_PROVIDER=
# HENCHMEN_OBJECT_STORE_PROVIDER=
# HENCHMEN_CONTAINER_ORCHESTRATOR_PROVIDER=
# HENCHMEN_CI_PROVIDER=

# =============================================================================
# ENVIRONMENT
# =============================================================================
HENCHMEN_ENVIRONMENT=dev

# =============================================================================
# GITHUB (required for full workflow, optional for dry-run)
# =============================================================================
# HENCHMEN_GITHUB_APP_ID=
# HENCHMEN_GITHUB_APP_PRIVATE_KEY_SECRET=
# HENCHMEN_GITHUB_DEFAULT_ORG=your-org
# HENCHMEN_GITHUB_DEFAULT_REPO=your-org/your-repo

# =============================================================================
# GIT IDENTITY
# =============================================================================
HENCHMEN_GIT_AUTHOR_NAME=Henchmen Operative
HENCHMEN_GIT_AUTHOR_EMAIL=henchmen-operative@noreply.local

# =============================================================================
# LOCAL PROVIDER
# =============================================================================
HENCHMEN_LLM_OLLAMA_BASE_URL=http://ollama:11434
HENCHMEN_LLM_OLLAMA_MODEL=llama3.2

# =============================================================================
# GCP (only when HENCHMEN_PROVIDER=gcp)
# =============================================================================
# HENCHMEN_GCP_PROJECT_ID=
# HENCHMEN_GCP_REGION=us-central1

# =============================================================================
# AWS (only when HENCHMEN_PROVIDER=aws)
# =============================================================================
# HENCHMEN_AWS_REGION=us-east-1
# HENCHMEN_AWS_ACCOUNT_ID=

# =============================================================================
# DIRECT API KEYS (only for openai/anthropic LLM providers)
# =============================================================================
# HENCHMEN_OPENAI_API_KEY=sk-...
# HENCHMEN_ANTHROPIC_API_KEY=sk-ant-...
