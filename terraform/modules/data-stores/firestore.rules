// Henchmen Firestore Security Rules.
//
// IAM bindings at the project level (google_project_iam_member) cannot
// express collection-level authorization for Firestore. Least-privilege
// access for the Mastermind service account is enforced here instead.
//
// This file is deployed by terraform as part of the data-stores module
// via google_firebaserules_ruleset + google_firebaserules_release. The
// ${mastermind_sa_email_pattern} template variable is substituted by
// the terraform templatefile() call at plan time.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only the mastermind service account may read or write any document.
    // The email pattern is interpolated from var.project_id so the rules
    // stay in sync with whichever GCP project the module is deployed into.
    allow read, write: if request.auth != null
      && request.auth.token.email.matches('${mastermind_sa_email_pattern}');
  }
}
